# ============================================================
# GAMER PLUG SOLUTION — Environment Variables
# Copy this file and rename it to: .env
# Fill in your own credentials below.
# ⚠️ NEVER commit .env to GitHub — it is already in .gitignore
# ============================================================

# ─────────────────────────────────────
# Supabase (REQUIRED — app won't start without these)
# Get from: https://app.supabase.com → Project Settings → API
# ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: Direct DB connection (only needed for migration scripts)
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ─────────────────────────────────────
# Paystack (for wallet top-ups & payments)
# Get from: https://dashboard.paystack.com → Settings → API Keys
# Leave as placeholder if not ready yet — app still renders without this
# ─────────────────────────────────────
PAYSTACK_SECRET_KEY=your_paystack_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# ─────────────────────────────────────
# CodeCraft API (Telecel / AirtelTigo data fulfillment)
# Leave blank if not using yet
# ─────────────────────────────────────
CODECRAFT_API_URL=https://api.codecraftnetwork.com/api
CODECRAFT_API_KEY=your_codecraft_api_key

# ─────────────────────────────────────
# MTN API (auto-fulfillment)
# Leave blank if not using yet
# ─────────────────────────────────────
MTN_API_KEY=your_mtn_api_key
MTN_API_BASE_URL=your_mtn_api_base_url

# ─────────────────────────────────────
# Moolre SMS Service
# Leave blank if not using yet — SMS will be disabled
# ─────────────────────────────────────
MOOLRE_API_KEY=your_moolre_api_key
MOOLRE_SENDER_ID=GAMERPLUG
SMS_ENABLED=false

# ─────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────
NEXT_PUBLIC_PAYMENT_MAINTENANCE_MODE=false

# ─────────────────────────────────────
# App URL
# Set to your Vercel production URL
# Also add this URL to: Supabase → Authentication → URL Configuration → Redirect URLs
# ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://gamerplug.vercel.app
NEXT_PUBLIC_SITE_URL=https://gamerplug.vercel.app

# ─────────────────────────────────────
# Cron Job Secret (set in Vercel Environment Variables too)
# Generate any random secret string
# ─────────────────────────────────────
CRON_SECRET=generate_a_random_secret_here
